{
  "seed": 0,
  "device": "auto",
  "experiment": {
    "name": "pendulum_fast_sac",
    "output_root": "runs"
  },
  "env": {
    "id": "Pendulum-v1",
    "kwargs": {}
  },
  "algorithm": {
    "actor_lr": 0.0003,
    "critic_lr": 0.0003,
    "alpha_lr": 0.0003,
    "hidden_dims": [
      256,
      256
    ],
    "discount": 0.99,
    "tau": 0.005,
    "init_temperature": 1.0,
    "target_entropy": null,
    "learnable_temperature": true,
    "log_std_min": -5.0,
    "log_std_max": 2.0,
    "replay_size": 200000,
    "updates_per_step": 16,
    "resets": false,
    "reset_interval_updates": 500000
  },
  "train": {
    "total_env_steps": 30000,
    "start_steps": 1000,
    "start_training_after": 1000,
    "batch_size": 256,
    "eval_every": 5000,
    "eval_episodes": 5,
    "video_episodes": 1
  }
}