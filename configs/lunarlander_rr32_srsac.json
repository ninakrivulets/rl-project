    "replay_size": 200000,
    "updates_per_step": 32,
    "resets": true,
    "reset_interval_updates": 2560000
  },
  "train": {
    "total_env_steps": 100000,
    "start_steps": 2000,
    "start_training_after": 2000,
    "batch_size": 256,
    "eval_every": 5000,
    "eval_episodes": 5,
    "video_episodes": 1
  }
