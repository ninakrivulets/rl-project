{
  "seed": 0,
  "device": "auto",
  "experiment": {
    "name": "lunarlander_rr32_srsac",
    "output_root": "runs"
  },
  "env": {
    "id": "LunarLanderContinuous-v3",
    "kwargs": {}
  },
  "algorithm": {
    "actor_lr": 0.0003,
    "critic_lr": 0.0003,
    "alpha_lr": 0.0003,
    "hidden_dims": [256, 256],
    "discount": 0.99,
    "tau": 0.005,
    "init_temperature": 1.0,
    "target_entropy": null,
